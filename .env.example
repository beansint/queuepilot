# QueuePilot environment — copy to .env and fill in. NEVER commit .env.
# See docs/final-build-plan/01-TECH-STACK-LOCKED.md.

# --- App ---
APP_NAME=QueuePilot
ENVIRONMENT=development
MAX_INPUT_CHARS=8000

# --- Providers (server-side only) ---
# Required from task A3 (embeddings) / A5 (Pinecone) / A7 (ingest) onward.
GEMINI_API_KEY=
# Voyage AI key (default embedding provider; 200M free tokens — see D11).
VOYAGE_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=queuepilot
# Pinecone serverless free-tier defaults
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Chat-LLM provider registry (Slice B). Default Groq (free, fast); Gemini/OpenAI are drop-ins.
CHAT_PROVIDER=groq
GROQ_API_KEY=
OPENAI_API_KEY=

# Kaggle API token (for data/download.py, task A7).
# Get one at https://www.kaggle.com/settings -> API -> "Create New Token" (downloads kaggle.json).
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- Retrieval ---
# Embedding provider registry (D11). Change triggers a full Pinecone re-index.
EMBEDDING_PROVIDER=voyage
# EMBED_DIM is PINNED to the active provider: voyage-3.5-lite @ 1024 dims (do not change without reindex).
EMBED_DIM=1024
CORPUS_CAP=3000
HYBRID_ALPHA=0.5

# --- Observability (Slice C, LangSmith) ---
# Off by default; graceful no-op everywhere when unset (no crash, trace.enabled=false).
# Note: the langsmith SDK itself reads LANGSMITH_TRACING / LANGSMITH_API_KEY / LANGSMITH_PROJECT /
# LANGSMITH_ENDPOINT directly from the environment, not from pydantic-settings. The app exports
# these Settings values to the process environment (os.environ) when tracing is enabled — see
# `_ensure_langsmith_env` in app/analyze/graph_analyzer.py — so .env-only values reach the SDK too.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=queuepilot
# Only needed for self-hosted / EU-region LangSmith; leave blank for the default SaaS endpoint.
LANGSMITH_ENDPOINT=
