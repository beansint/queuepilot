# QueuePilot environment — copy to .env and fill in. NEVER commit .env.
# See docs/final-build-plan/01-TECH-STACK-LOCKED.md.

# --- App ---
APP_NAME=QueuePilot
ENVIRONMENT=development
MAX_INPUT_CHARS=8000

# --- Providers (server-side only) ---
# Required from task A3 (embeddings) / A5 (Pinecone) / A7 (ingest) onward.
GEMINI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX=queuepilot
# Pinecone serverless free-tier defaults
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Chat-LLM provider registry (used from Slice B; OpenAI is a drop-in).
OPENAI_API_KEY=
GROQ_API_KEY=

# --- Retrieval ---
# EMBED_DIM is PINNED at A3: gemini-embedding-001 Matryoshka at 768 dims (do not change without reindex).
EMBED_DIM=768
CORPUS_CAP=3000
HYBRID_ALPHA=0.5
