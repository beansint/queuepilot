# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Env / secrets
.env
.env.*
!.env.example

# Data (large / generated)
data/raw/
data/*.csv
*.parquet

# OS / editor
.DS_Store
.idea/
.vscode/

# Generated retrieval artifacts — ignore the dir's contents EXCEPT the fitted BM25 vocab,
# which is required at runtime (the Dockerfile COPYs it) and is committed so the image can
# build from a clean checkout (Render/CI). It is derived "system state" (07-DATASET.md),
# small (~42KB), and not secret. Raw corpus + other artifacts stay ignored.
data/artifacts/*
!data/artifacts/bm25_params.json

# Claude Code internal worktrees/state
.claude/

# Playwright MCP scratch artifacts
.playwright-mcp/

# UI design exploration mockups (chosen spec lands with the Slice C frontend build)
design/

# Frontend build + deps (source lives in frontend/, dist built in Docker for Slice E)
frontend/node_modules/
frontend/dist/

# Generated eval snapshot cards (go stale; regenerate via eval/run_experiment.py or
# eval/run_online.py). eval/snapshots/.gitkeep is intentionally NOT covered by this.
eval/snapshots/*.json
eval/snapshots/*.md
